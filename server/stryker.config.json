{
  "$schema": "https://schema.stryker-mutator.io/stryker-config.json",
  "mutate": [
    "src/features/operations/crowd.ts",
    "src/lib/ttl-cache.ts",
    "src/lib/app-error.ts",
    "src/lib/async-utils.ts"
  ],
  "testRunner": "vitest",
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "reporters": ["progress", "clear-text", "html"],
  "coverageAnalysis": "perTest",
  "thresholds": {
    "high": 90,
    "low": 80,
    "break": 90
  }
}
